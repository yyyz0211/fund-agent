# Fund Agent — 本地 / 闲置电脑部署环境变量模板
# ----------------------------------------------------
# 复制: cp .env.example .env   然后填实际值
# ----------------------------------------------------

# ---- PostgreSQL ----
# 第一次启动后这套就固定了,改密码会创建新库。仅本机 / Docker 内使用,不会暴露公网。
POSTGRES_DB=fund_agent
POSTGRES_USER=fund
POSTGRES_PASSWORD=change-me-to-a-strong-passphrase-32-chars-min

# ---- 数据库连接 ----
# 默认 SQLite (本地开发); 切到 PostgreSQL 时改 DATABASE_URL 为:
#   postgresql://fund:change-me-to-a-strong-passphrase-32-chars-min@localhost:5432/fund_agent
# 注意:改 DATABASE_URL 后请同时检查 DB_POOL_SIZE 等连接池参数。
DATABASE_URL=sqlite:///backend/data/fund_agent.db

# 连接池参数 (仅非 SQLite 方言生效):
#   - DB_POOL_SIZE: 常驻连接数 (uvicorn workers × 每 worker 并发数，建议 5)
#   - DB_MAX_OVERFLOW: 允许超发的连接数 (突发流量，建议 10)
#   - DB_POOL_TIMEOUT_SECONDS: 连接等待超时，超过此时长抛 TimeoutError
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT_SECONDS=10.0

# ---- DeepSeek API ----
# 申请: https://platform.deepseek.com  (国内友好,按 token 计费)
DEEPSEEK_API_KEY=sk-put-your-real-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---- 网络 / CORS ----
# 你在这台机器上跑 `tailscale ip -4` 拿到的 IPv4,通常是 100.x.x.x
# 朋友通过这个地址访问,你也在同一 Tailscale 网络里访问。
# 把 100.x.x.x 写进 ALLOWED_ORIGINS,前端访问后端就不会被 CORS 拦。
ALLOWED_ORIGINS=http://100.x.x.x:3000,http://localhost:3000

# 这两个写给你前端用的"基地址"。要写 Tailscale IP,不能写 localhost
# (朋友侧解析不到 localhost)。
NEXT_PUBLIC_API_BASE_URL=http://100.x.x.x:8000
NEXT_PUBLIC_LANGGRAPH_URL=http://100.x.x.x:2024

# ---- 端口映射 ----
# 如果机器上 3000 / 8000 / 2024 被占了,改成别的(比如 :13000 / :18000 / :12024),
# 同步修改上方 NEXT_PUBLIC_* 的端口号。
BACKEND_PORT=8000
FRONTEND_PORT=3000
LANGGRAPH_PORT=2024

# ---- 时区 ----
TZ=Asia/Shanghai

# ---- 定时刷新调度 (后端) ----
# 进程内 APScheduler,每天定时遍历自选池刷 NAV + 体检画像。
# 关闭 = 不起后台线程(测试 / CI 默认就是关闭)。
# cron 时间按 SCHEDULER_TIMEZONE 解释,默认北京时间。
SCHEDULER_ENABLED=true
SCHEDULER_REFRESH_CRON_HOUR=20
SCHEDULER_REFRESH_CRON_MINUTE=0
SCHEDULER_TIMEZONE=Asia/Shanghai

# 注意:/api/admin/* 端点(手动触发放量刷新、查看上次刷新状态)无鉴权。
# 仅依赖 Tailscale 网络边界信任模型 — 同网络内的访客都能调用。
# 若以后对外开放,需要把 admin 改成 localhost-only 或加 token。

# ---- 财联社电报信息源 (后端) ----
# 用于 post_market evidence 自动采集和 QA 实时搜索。不保存完整长文。
CLS_ENABLED=true
CLS_SEARCH_ENABLED=true
CLS_TIMEOUT_SECONDS=5
CLS_CATEGORIES=fund,watch,announcement,hk_us,red,remind
CLS_PER_CATEGORY_LIMIT=10
CLS_MAX_SEARCH_LIMIT=10
CLS_APP_VERSION=8.7.9
CLS_TELEGRAPH_SYNC_ENABLED=true
CLS_TELEGRAPH_SYNC_INTERVAL_SECONDS=360
CLS_TELEGRAPH_SYNC_PAGE_SIZE=50
CLS_TELEGRAPH_SYNC_MAX_PAGES=3

# ---- 知识库 / RAG 检索 (后端) ----
# 原始数据仍保存在源表,知识库只保存 LLM 准入后的可检索知识。
KNOWLEDGE_RAG_ENABLED=true
KNOWLEDGE_VECTOR_BACKEND=auto
KNOWLEDGE_EMBEDDING_BASE_URL=
KNOWLEDGE_EMBEDDING_API_KEY=
KNOWLEDGE_EMBEDDING_MODEL=
KNOWLEDGE_EMBEDDING_VERSION=
KNOWLEDGE_EMBEDDING_DIMENSIONS=
KNOWLEDGE_CLASSIFICATION_MODEL=
KNOWLEDGE_CLASSIFICATION_PROMPT_VERSION=v1
KNOWLEDGE_CLASSIFICATION_BATCH_SIZE=10
KNOWLEDGE_INDEX_BATCH_SIZE=20
KNOWLEDGE_INDEX_MAX_ATTEMPTS=3
KNOWLEDGE_INDEX_RETRY_SECONDS=300
KNOWLEDGE_DEFAULT_TTL_DAYS=14
KNOWLEDGE_INCLUDE_PENDING_FALLBACK=true
KNOWLEDGE_MAX_SEARCH_LIMIT=50
KNOWLEDGE_MAX_QUEUE_STATUS_LIMIT=200
SCHEDULER_KNOWLEDGE_ENABLED=true
SCHEDULER_KNOWLEDGE_INTERVAL_MINUTES=6
