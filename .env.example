# Fund Agent — 本地 / 闲置电脑部署环境变量模板
# ----------------------------------------------------
# 复制: cp .env.example .env   然后填实际值
# ----------------------------------------------------

# ---- PostgreSQL ----
# 第一次启动后这套就固定了,改密码会创建新库。仅本机 / Docker 内使用,不会暴露公网。
POSTGRES_DB=fund_agent
POSTGRES_USER=fund
POSTGRES_PASSWORD=change-me-to-a-strong-passphrase-32-chars-min

# ---- DeepSeek API ----
# 申请: https://platform.deepseek.com  (国内友好,按 token 计费)
DEEPSEEK_API_KEY=sk-put-your-real-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---- 网络 / CORS ----
# 你在这台机器上跑 `tailscale ip -4` 拿到的 IPv4,通常是 100.x.x.x
# 朋友通过这个地址访问,你也在同一 Tailscale 网络里访问。
# 把 100.x.x.x 写进 ALLOWED_ORIGINS,前端访问后端就不会被 CORS 拦。
ALLOWED_ORIGINS=http://100.x.x.x:3000,http://localhost:3000

# 这两个写给你前端用的"基地址"。要写 Tailscale IP,不能写 localhost
# (朋友侧解析不到 localhost)。
NEXT_PUBLIC_API_BASE_URL=http://100.x.x.x:8000
NEXT_PUBLIC_LANGGRAPH_URL=http://100.x.x.x:2024

# ---- 端口映射 ----
# 如果机器上 3000 / 8000 / 2024 被占了,改成别的(比如 :13000 / :18000 / :12024),
# 同步修改上方 NEXT_PUBLIC_* 的端口号。
BACKEND_PORT=8000
FRONTEND_PORT=3000
LANGGRAPH_PORT=2024

# ---- 时区 ----
TZ=Asia/Shanghai
